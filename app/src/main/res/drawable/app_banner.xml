<?xml version="1.0" encoding="utf-8"?>
<!-- 320x180 TV banner -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="135"
                android:startColor="#0B1A2E"
                android:endColor="#13315C" />
        </shape>
    </item>
    <item
        android:width="56dp"
        android:height="56dp"
        android:gravity="center_vertical|start"
        android:left="24dp">
        <shape android:shape="oval">
            <solid android:color="#7FB2FF" />
        </shape>
    </item>
</layer-list>
